models:
  # Default model used when no agent-specific model is set
  default: gemini-2.5-pro

  # Agent-specific overrides — use a more capable model for complex reasoning
  orchestrator: gemini-2.5-pro
  repo_checker: gemini-2.5-pro
  platform_checker: gemini-2.5-pro
  correlator: gemini-2.5-pro
  reporter: gemini-2.5-pro
